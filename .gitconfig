[user]
  name = Georg Friedrich
	email = georg@codezero.io
[column]
  ui = auto
[core]
  editor = nvim
  excludesfile = ~/.gitignore-global
[alias]
  co = checkout
  cb = checkout -b
  ci = commit -v
  ca = commit -av
  st = status -sb
  up = pull
  log-graph = log --graph --all --decorate
  ctags = !.git/hooks/ctags
  amend = commit --amend -C HEAD
[apply]
  whitespace = strip
[branch]
  autosetupmerge = true
  sort = -committerdate
[color]
  diff = auto
  grep = auto
  branch = auto
  interactive = auto
  pager = true
  showbranch = auto
  status = auto
  ui = auto
[difftool]
  cmd = "opendiff $LOCAL $REMOTE"
[merge]
  tool = opendiff
[mergetool]
  keepBackup = false
[mergetool "opendiff"]
  cmd = "opendiff $LOCAL $REMOTE -ancestor $BASE -merge $MERGED"
[push]
  default = simple
  autoSetupRemote = true
  followTags = true
[fetch]
  prune = true
  pruneTags = true
  all = true
[rerere]
  enabled = 1
  autoupdate = true
[init]
  templatedir = ~/.git_template
	defaultBranch = main
[hub]
  protocol = https

[pull]
rebase = merges
[tag]
  sort = version:refname

[credential]
	helper = osxkeychain
[diff]
	renameLimit = 2580
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[rebase]
	autoSquash = true
  autoStash = true
  updateRefs = true
[commit]
  gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
